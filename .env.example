# LOCAL runs only. Copy this file to `.env` (which is gitignored) and fill in values.
#   cp .env.example .env
# In GitHub Actions these are NOT read from a file — set them as repository Secrets.
# NEVER put real secrets in config.yaml or any committed file (the repo is public).

OPENAI_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=

# Your resume drives the experience score. Locally you can leave RESUME_TEXT blank
# and instead put your resume in a gitignored `resume.txt` at the repo root.
# In Actions, set RESUME_TEXT as a secret.
RESUME_TEXT=
