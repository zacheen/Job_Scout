# LOCAL runs only. Copy to `.env` (gitignored) and fill in:  cp .env.example .env
# GitHub Actions never reads this file — set the same names as repository Secrets.
# NEVER put real secrets in config.yaml or any committed file (the repo is public).

# Gmail SMTP sender + recipient. GMAIL_APP_PASSWORD is a 16-char App Password
# (requires 2FA: Google Account > Security > 2-Step Verification > App passwords) —
# your normal login password is rejected by SMTP (535).
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=

# Optional. Scoring uses the best available tier: OpenAI API > local GPT CLI > keyword-only.
# Key comes from platform.openai.com (its own billing) — a ChatGPT subscription is NOT an API key.
OPENAI_API_KEY=

# Optional: full path to the GPT CLI exe (tier 2; used only when OPENAI_API_KEY is blank),
# for when `codex` isn't on the process PATH. No quotes, spaces are fine; the "exec"
# subcommand comes from config.yaml (gpt_cli_args).
GPT_CLI=

# Optional: separate local ledger so local runs don't share "seen" state with the
# cloud ledger (kept on the `data` branch). Gitignored via *.local.csv.
# LEDGER_FILE=data/seen_jobs.local.csv

# Resume text that drives the experience score. Locally you may leave this blank and
# put your resume in a gitignored `resume.txt` at the repo root instead.
# In Actions, set RESUME_TEXT as a secret.
RESUME_TEXT=
