# LOCAL runs only. Copy this file to `.env` (which is gitignored) and fill in values.
#   cp .env.example .env
# In GitHub Actions these are NOT read from a file — set them as repository Secrets.
# NEVER put real secrets in config.yaml or any committed file (the repo is public).

OPENAI_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=

# Optional: override the GPT CLI executable (used only when OPENAI_API_KEY is blank),
# for when `codex` isn't on the process PATH. Full path to the exe only — no quotes,
# spaces are fine; the "exec" subcommand comes from config.yaml (gpt_cli_args).
GPT_CLI=

# Optional: use a separate ledger locally so local runs don't share "seen" state
# with the committed cloud ledger (lets you re-evaluate the same jobs with a
# smarter model). Gitignored via *.local.csv.
# LEDGER_FILE=data/seen_jobs.local.csv

# Your resume drives the experience score. Locally you can leave RESUME_TEXT blank
# and instead put your resume in a gitignored `resume.txt` at the repo root.
# In Actions, set RESUME_TEXT as a secret.
RESUME_TEXT=
